# SQLite utilisé par défaut (fichier prisma/dev.db). Aucune variable requise.

# URL du site (pour le sitemap et le SEO). En prod, mettre l’URL réelle.
# NEXT_PUBLIC_SITE_URL="https://votre-domaine.com"

# Pour PostgreSQL (prod ou équipe) : dans prisma/schema.prisma mettre
#   provider = "postgresql"
#   url      = env("DATABASE_URL")
# puis définir :
# DATABASE_URL="postgresql://user:password@localhost:5432/gen_factures?schema=public"
